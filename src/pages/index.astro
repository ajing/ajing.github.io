---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import Hr from "@/components/Hr.astro";
import { getPath } from "@/utils/getPath";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";
import { TOPICS } from "@/data/topics";
import {
  itemListStructuredData,
  personStructuredData,
  websiteStructuredData,
} from "@/utils/structuredData";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homeUrl = new URL("/", Astro.url.origin).href;
const recentPostEntries = sortedPosts.slice(0, 10).map(post => ({
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  url: new URL(`${getPath(post.id, post.filePath)}/`, Astro.url.origin).href,
  datePublished: post.data.pubDatetime.toISOString(),
  ...(post.data.modDatetime && {
    dateModified: post.data.modDatetime.toISOString(),
  }),
  author: personStructuredData(),
}));
---

<Layout
  structuredData={[
    websiteStructuredData(homeUrl),
    personStructuredData(),
    {
      "@context": "https://schema.org",
      "@type": "Blog",
      name: SITE.title,
      url: homeUrl,
      description: SITE.desc,
      author: personStructuredData(),
      blogPost: recentPostEntries,
    },
    itemListStructuredData(
      sortedPosts.slice(0, 10).map(post => ({
        name: post.data.title,
        url: new URL(
          `${getPath(post.id, post.filePath)}/`,
          Astro.url.origin
        ).href,
        description: post.data.description,
      }))
    ),
  ]}
>
  <Header />
  <main id="main-content" data-layout="index">
    <section id="hero" class="pt-8 pb-6">
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        ML & AI in Action
      </h1>
      <a
        target="_blank"
        href="/index.xml"
        class="inline-block"
        aria-label="rss feed"
        title="RSS Feed"
      >
        <IconRss
          width={20}
          height={20}
          class="stroke-accent scale-125 stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS Feed</span>
      </a>

      <p>
        Practical insights on machine learning, AI systems, and building
        products that ship. Topics include RLHF, LLM optimization, recommender
        systems, and generative UI.
      </p>
      {
        // only display if at least one social link is enabled
        SOCIALS.length > 0 && (
          <div class="mt-4 flex flex-col sm:flex-row sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">Social Links:</div>
            <Socials />
          </div>
        )
      }
      <div class="mt-6 flex flex-wrap gap-3">
        <LinkButton href="/start-here/">
          Start Here
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
        <LinkButton href="/topics/">Topic Hubs</LinkButton>
      </div>
    </section>

    <Hr />

    <section id="topics" class="pt-12 pb-6">
      <h2 class="text-2xl font-semibold tracking-wide">Topic Hubs</h2>
      <ul class="mt-4 grid gap-4 sm:grid-cols-2">
        {
          TOPICS.map((topic) => (
            <li>
              <a
                href={`/topics/${topic.slug}/`}
                class="text-accent text-lg font-medium decoration-dashed underline-offset-4 hover:underline"
              >
                {topic.title}
              </a>
              <p class="mt-1 text-sm opacity-85">{topic.description}</p>
            </li>
          ))
        }
      </ul>
    </section>

    <Hr />

    {
      featuredPosts.length > 0 && (
        <>
          <section id="featured" class="pt-12 pb-6">
            <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
            <ul>
              {featuredPosts.map((data) => (
                <Card variant="h3" {...data} />
              ))}
            </ul>
          </section>
          {recentPosts.length > 0 && <Hr />}
        </>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />,
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
